# ─── Flask ───────────────────────────────────────────────
FLASK_ENV=development
SECRET_KEY=cambiar-por-clave-secreta-aleatoria

# ─── CORS ────────────────────────────────────────────────
# Dominios permitidos separados por coma (sin espacios)
ALLOWED_ORIGINS=http://localhost:4200

# ─── Cloudflare Turnstile ────────────────────────────────
TURNSTILE_SECRET_KEY=tu-secret-key-de-turnstile
TURNSTILE_VERIFY_URL=https://challenges.cloudflare.com/turnstile/v0/siteverify

# ─── Gmail SMTP ──────────────────────────────────────────
# Cuenta de Gmail desde la que se enviarán los emails de notificación.
GMAIL_USER=tu-correo@gmail.com
# Contraseña de aplicación de 16 caracteres (NO la contraseña de Gmail).
# Para generarla:
#   1. Activa la verificación en dos pasos en tu cuenta de Google.
#   2. Ve a https://myaccount.google.com/apppasswords
#   3. Crea una contraseña de aplicación para "Correo" → "Otro (Stay Sidekick)".
#   4. Copia los 16 caracteres aquí SIN espacios.
GMAIL_APP_PASSWORD=xxxx-xxxx-xxxx-xxxx
# Correo que recibirá las solicitudes del formulario de contacto.
MAIL_RECIPIENT=destinatario@ejemplo.com

# ─── Discord Webhook ─────────────────────────────────────
# Webhook del canal de Discord para solicitudes de empresa (formulario /solicitud).
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/TU_ID/TU_TOKEN
# Webhook del canal de Discord para mensajes de contacto general (/empresa/contacto).
DISCORD_WEBHOOK_CONTACT_URL=https://discord.com/api/webhooks/TU_ID/TU_TOKEN

# ─── Rate Limiting ───────────────────────────────────────
RATE_LIMIT_CONTACT=5/hour

# ─── JWT (panel autenticado) ─────────────────────────────
# Clave secreta para firmar tokens JWT (mín. 32 caracteres aleatorios).
# Generar con: python -c "import secrets; print(secrets.token_urlsafe(32))"
JWT_SECRET_KEY=cambiar-por-clave-secreta-aleatoria-jwt
# Duración del token de acceso en horas.
JWT_ACCESS_TOKEN_HOURS=1

# ─── Cifrado Fernet (API keys en BD) ────────────────────
# Clave Fernet para cifrar/descifrar API keys almacenadas en PostgreSQL.
# Generar con: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
FERNET_KEY=

# ─── IA — proveedor por defecto y límites free tier ──────
# Proveedor por defecto: gemini | openai | claude
AI_DEFAULT_PROVIDER=gemini
# Modelo LiteLLM (gemini/gemini-2.0-flash, gpt-4o-mini, claude-haiku-3, etc.)
AI_DEFAULT_MODEL=gemini/gemini-2.0-flash
# API key del sistema (se usa cuando la empresa no tiene BYOK configurado)
AI_DEFAULT_API_KEY=AIzaSy...
# Límite de llamadas gratuitas diarias por empresa
AI_FREE_LIMIT_DAILY=100
# Límite de llamadas gratuitas semanales por empresa
AI_FREE_LIMIT_WEEKLY=500
# IPs autorizadas para gestionar system prompts (separadas por coma)
AI_PROMPT_ADMIN_IPS=127.0.0.1

# ─── PostgreSQL ──────────────────────────────────────────
# URI de conexión a la base de datos PostgreSQL.
# Con docker compose: el host es "postgres" (nombre del servicio).
#   → docker-compose.yml inyecta DATABASE_URL automáticamente; no hace falta cambiarlo.
# Sin docker compose (dev directo en local): cambiar "postgres" por "localhost".
DATABASE_URL=postgresql://postgres:postgres@postgres:5432/stay_sidekick

# ---- Smoobu API Key ----
# Clave API de Smoobu para integración de reservas.
# Generar en el panel de Smoobu: Configuración → API → Crear nueva clave
SMOOBU_API_KEY=tu-api-key
