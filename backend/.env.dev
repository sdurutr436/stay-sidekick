# =============================================================================
# .env.dev — Variables de entorno para desarrollo local con Docker Compose
#
# Uso: docker compose -f docker-compose.yml -f docker-compose.dev.yml up -d --build
#
# NO USAR EN PRODUCCIÓN. Todos los valores son ficticios o de prueba.
# Este archivo es seguro de commitear: no contiene secretos reales.
# =============================================================================

# Flask
FLASK_ENV=development
SECRET_KEY=dev-secret-key-only-for-local-docker

# JWT
JWT_SECRET_KEY=dev-jwt-secret-key-only-for-local-docker
JWT_ACCESS_TOKEN_HOURS=8

# Cifrado Fernet (API keys en BD) — clave de prueba, solo para dev
# Generada con: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
FERNET_KEY=AAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAA=

# Cloudflare Turnstile — clave de prueba oficial (siempre pasa en dev)
TURNSTILE_SECRET_KEY=1x0000000000000000000000000000000AA
TURNSTILE_VERIFY_URL=https://challenges.cloudflare.com/turnstile/v0/siteverify

# Google OAuth 2.0 — deshabilitado en dev (no hay credenciales reales)
# Para probar OAuth en local, registrar una app en Google Cloud Console y rellenar.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost/api/contactos/google/callback

# Frontend base URL — a través de nginx local
FRONTEND_BASE_URL=http://localhost

# Email (deshabilitado en dev — las rutas que lo usan no se usan en pruebas XLSX)
GMAIL_USER=
GMAIL_APP_PASSWORD=
MAIL_RECIPIENT=dev@localhost

# Discord (deshabilitado en dev)
DISCORD_WEBHOOK_URL=
DISCORD_WEBHOOK_CONTACT_URL=

# Rate limiting (más permisivo en dev)
RATE_LIMIT_CONTACT=1000/hour

# Base de datos — inyectada por docker-compose, no cambiar
DATABASE_URL=postgresql://postgres:postgres@postgres:5432/stay_sidekick

# Puerto de escucha (Railway lo usa; docker-compose lo ignora)
PORT=5000

# Smoobu — deshabilitado en dev
SMOOBU_API_KEY=
