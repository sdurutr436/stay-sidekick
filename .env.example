# Variables de entorno raíz — docker compose
# Copiar a .env antes de ejecutar docker compose:
#
#   cp .env.example .env
#
# Para producción, cambiar POSTGRES_PASSWORD y actualizar DATABASE_URL acorde.
# NOTA: los ficheros .env no interpolan variables — DATABASE_URL debe ser literal.

# ── PostgreSQL ────────────────────────────────────────────────────────────────
POSTGRES_DB=stay_sidekick
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
# Debe reflejar POSTGRES_USER, POSTGRES_PASSWORD y POSTGRES_DB de arriba.
# Host "postgres" = nombre del servicio en docker-compose. En Railway, usar la URL del plugin Postgres.
DATABASE_URL=postgresql://postgres:postgres@postgres:5432/stay_sidekick

# ── Cloudflare Turnstile (build arg del sitio 11ty) ───────────────────────────
# Key de prueba oficial (siempre válida en desarrollo).
# En producción, sustituir por la site key real del Dashboard de Cloudflare.
TURNSTILE_SITE_KEY=1x00000000000000000000AA
