# Variables de entorno raíz — PostgreSQL
# Copiar a .env y completar POSTGRES_PASSWORD antes de ejecutar docker compose
#
#   cp .env.example .env   # luego editar .env con la contraseña real

POSTGRES_DB=stay_sidekick
POSTGRES_USER=postgres
POSTGRES_PASSWORD=cambiar-en-produccion
DATABASE_URL=postgresql://${POSTGRES_USER}:${POSTGRES_PASSWORD}@postgres:5432/${POSTGRES_DB}
