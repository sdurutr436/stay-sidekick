<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="description" content="{{ description or site.description }}" />

  {# Favicon: ICO clásico + PNG/WebP modernos. La variante dark se sirve
     cuando el sistema declara prefers-color-scheme: dark (los navegadores no
     respetan nuestra clase .dark en el favicon de la pestaña). #}
  <link rel="icon" type="image/x-icon" href="/assets/img/favicon/stay-sidekick-fav-icon-512x512.ico" />
  <link rel="icon" type="image/webp" sizes="600x600" href="/assets/img/favicon/stay-sidekick-fav-icon-600x600.webp" />
  <link rel="icon" type="image/png"  sizes="512x512" href="/assets/img/favicon/stay-sidekick-fav-icon-512x512.png" />
  <link rel="icon" type="image/png"  sizes="512x512"
        media="(prefers-color-scheme: dark)"
        href="/assets/img/favicon/stay-sidekick-fav-icon-dark-mode-512x512.png" />

  {# Inline pre-paint para evitar FOUC al alternar tema claro/oscuro #}
  <script>
    (function () {
      try {
        var stored = localStorage.getItem('theme');
        var theme = (stored === 'light' || stored === 'dark') ? stored
          : (window.matchMedia && window.matchMedia('(prefers-color-scheme: dark)').matches ? 'dark' : 'light');
        document.documentElement.classList.toggle('dark', theme === 'dark');
        document.documentElement.setAttribute('data-theme', theme);
      } catch (_) { /* no-op */ }
    }());
  </script>

  <title>{% if title %}{{ title }} | {% endif %}{{ site.name }}</title>

  <!-- Fuente: Archivo — preconnect para rendimiento -->
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link
    rel="stylesheet"
    href="https://fonts.googleapis.com/css2?family=Archivo:ital,wght@0,100..900;1,100..900&display=swap"
  />

  <!-- Estilos globales compilados desde SCSS compartido con Angular -->
  <link rel="stylesheet" href="/assets/styles/main.css" />

  {% block head %}{% endblock %}

    <script type="application/ld+json">
      {{ {
        "@context": "https://schema.org",
        "@graph": [
          {
            "@type": "Organization",
            "@id": site.url + "/#organization",
            "name": site.name,
            "url": site.url
          },
          {
            "@type": "WebSite",
            "@id": site.url + "/#website",
            "url": site.url,
            "name": site.name,
            "description": site.description,
            "publisher": { "@id": site.url + "/#organization" }
          }
        ]
      } | dump | safe }}
  </script>
</head>
<body class="l-page">

  <a class="skip-link" href="#main-content">Saltar al contenido</a>

  {% import "macros/atoms.njk" as atoms %}
  {% import "macros/molecules.njk" as molecules %}
  {% import "macros/organisms.njk" as organisms %}

  {% include "partials/header.njk" %}

  <main class="l-page__main" id="main-content">
    {{ content | safe }}
  </main>

  {% include "partials/footer.njk" %}

  <script src="/assets/js/header-auth.js" defer></script>
  <script src="/assets/js/theme-toggle.js" defer></script>
  {% block scripts %}{% endblock %}
</body>
</html>
