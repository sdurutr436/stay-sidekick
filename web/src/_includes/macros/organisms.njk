{# ── pageHeader ───────────────────────────────────────────────────────────── #}
{# Espejo de app-page-header: estructura BEM completa para _page-header.scss  #}
{# @param {String} title           Título principal de la página. Requerido. #}
{# @param {String} [subtitle='']   Subtítulo descriptivo opcional.           #}
{% macro pageHeader(title, subtitle='') %}
  <div class="page-header">
    <div class="page-header__start">
      <h1 class="page-header__title">{{ title }}</h1>
      {% if subtitle %}
        <p class="page-header__desc">{{ subtitle }}</p>
      {% endif %}
    </div>
  </div>
{% endmacro %}
