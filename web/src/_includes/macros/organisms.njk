{# ── pageHeader ───────────────────────────────────────────────────────────── #}
{% macro pageHeader(title, subtitle='') %}
  <div class="page-header">
    <h1>{{ title }}</h1>
    {% if subtitle %}
      <p>{{ subtitle }}</p>
    {% endif %}
  </div>
{% endmacro %}
