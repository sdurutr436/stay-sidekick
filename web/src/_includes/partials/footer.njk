{#
  PARTIAL: FOOTER
  Estructura BEM idéntica al componente Angular (footer.html)
  Los estilos provienen de styles/components/_footer.scss (compartido)
#}
<footer class="footer l-page__footer">
  <div class="footer__inner">
    <div class="footer__grid">

      {# Col 1: Brand — doble picture (light/dark) gestionada por CSS .dark #}
      <div class="footer__brand">
        <a href="/" aria-label="{{ site.name }} — Ir a inicio">
          <picture class="footer__brand-img footer__brand-img--light">
            <source
              media="(max-width: 767px)"
              srcset="/assets/img/favicon/stay-sidekick-fav-icon-512x512.png"
              type="image/png">
            <source
              srcset="/assets/img/footer/stay-sidekick-512x256-light-mode.webp 512w,
                      /assets/img/footer/stay-sidekick-1024x576-light-mode.webp 1024w"
              type="image/webp"
              sizes="(max-width: 767px) 160px, 200px">
            <source
              srcset="/assets/img/footer/stay-sidekick-512x256-light-mode.png 512w,
                      /assets/img/footer/stay-sidekick-1024x576-light-mode.png 1024w"
              type="image/png"
              sizes="(max-width: 767px) 160px, 200px">
            <img
              class="logo__img"
              src="/assets/img/footer/stay-sidekick-512x256-light-mode.png"
              alt="{{ site.name }}"
              width="512"
              height="256"
              loading="lazy"
              decoding="async"
            >
          </picture>
          <picture class="footer__brand-img footer__brand-img--dark">
            <source
              media="(max-width: 767px)"
              srcset="/assets/img/favicon/stay-sidekick-fav-icon-dark-mode-512x512.png"
              type="image/png">
            <source
              srcset="/assets/img/footer/stay-sidekick-1024x576-dark-mode.webp"
              type="image/webp"
              sizes="(max-width: 767px) 160px, 200px">
            <source
              srcset="/assets/img/footer/stay-sidekick-1024x576-dark-mode.png"
              type="image/png"
              sizes="(max-width: 767px) 160px, 200px">
            <img
              class="logo__img"
              src="/assets/img/footer/stay-sidekick-1024x576-dark-mode.png"
              alt=""
              width="1024"
              height="576"
              loading="lazy"
              decoding="async"
              aria-hidden="true"
            >
          </picture>
        </a>
        <p class="footer__description">
          Tu copiloto para gestionar alojamientos turísticos con autonomía y sin fricciones.
        </p>
      </div>

      {# Cols 2-4: Grupos de navegación desde site.footerNav #}
      {% for group in site.footerNav %}
      <nav class="footer__nav" aria-label="{{ group.label }}">
        <h3 class="footer__nav-title">{{ group.label }}</h3>
        <ul class="footer__nav-list">
          {% for link in group.links %}
          <li class="footer__nav-item">
            <a href="{{ link.href }}" class="footer__nav-link">{{ link.text }}</a>
          </li>
          {% endfor %}
        </ul>
      </nav>
      {% endfor %}

      {# Col 5: Redes sociales desde site.social #}
      <nav class="footer__nav" aria-label="Redes sociales">
        <h3 class="footer__nav-title">Redes sociales</h3>
        <ul class="footer__nav-list">
          {% for item in site.social %}
          <li class="footer__nav-item">
            <a href="{{ item.href }}" class="footer__nav-link"
               target="_blank" rel="noopener noreferrer"
               aria-label="{{ item.label }}">{{ item.text }}</a>
          </li>
          {% endfor %}
        </ul>
      </nav>

    </div>{# /.footer__grid #}
  </div>{# /.footer__inner #}

  {# Barra de copyright #}
  <div class="footer__bar">
    <p class="footer__copyright">
      &copy; {% year %} {{ site.name }} &middot; Todos los derechos reservados
    </p>
  </div>
</footer>
