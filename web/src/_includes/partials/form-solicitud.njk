{#
  PARTIAL: FORM-SOLICITUD
  Formulario de presentar solicitud / nueva herramienta
  BEM: .form-solicitud (organismo)
  Wireframe: estilos blocky, escala de grises
#}
{% import "macros/atoms.njk" as atoms %}
{% import "macros/molecules.njk" as molecules %}

<form
  class="form-solicitud"
  id="form-solicitud"
  method="post"
  action="/api/contact"
  novalidate
>

  {# ── Honeypot — oculto para usuarios, atrae bots ──────────────────── #}
  <div class="form-solicitud__honeypot" aria-hidden="true">
    <label for="website">No rellenes este campo</label>
    <input
      type="text"
      id="website"
      name="website"
      tabindex="-1"
      autocomplete="off"
    />
  </div>

  {# ── Datos de la empresa ───────────────────────────────────────────── #}
  <div class="form-solicitud__section">

    {% call molecules.formField('Nombre de la empresa', 'empresa-nombre') %}
      {% call molecules.formInputIcon() %}
        <span class="form-input-wrapper__icon" aria-hidden="true">
          <svg class="svg svg--md" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 256 256" fill="currentColor">
            <path d="M240,208H224V96a16,16,0,0,0-16-16H144V32a16,16,0,0,0-24.88-13.32L39.12,72A16,16,0,0,0,32,85.34V208H16a8,8,0,0,0,0,16H240a8,8,0,0,0,0-16ZM208,96V208H144V96ZM48,85.34,128,32V208H48ZM112,112v16a8,8,0,0,1-16,0V112a8,8,0,1,1,16,0Zm-32,0v16a8,8,0,0,1-16,0V112a8,8,0,1,1,16,0Zm0,56v16a8,8,0,0,1-16,0V168a8,8,0,0,1,16,0Zm32,0v16a8,8,0,0,1-16,0V168a8,8,0,0,1,16,0Z"/>
          </svg>
        </span>
        <input
          class="form-input"
          type="text"
          id="empresa-nombre"
          name="company_name"
          placeholder="Nombre de la empresa..."
          autocomplete="organization"
          maxlength="150"
        />
      {% endcall %}
    {% endcall %}

    {% call molecules.formField('Correo de contacto', 'empresa-correo') %}
      {% call molecules.formInputIcon() %}
        <span class="form-input-wrapper__icon" aria-hidden="true">
          <svg class="svg svg--md" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 256 256" fill="currentColor">
            <path d="M224,48H32a8,8,0,0,0-8,8V192a16,16,0,0,0,16,16H216a16,16,0,0,0,16-16V56A8,8,0,0,0,224,48Zm-96,85.15L52.57,64H203.43ZM98.71,128,40,181.81V74.19Zm11.84,10.85,12,11.05a8,8,0,0,0,10.82,0l12-11.05,58,53.15H52.57ZM157.29,128,216,74.18V181.82Z"/>
          </svg>
        </span>
        <input
          class="form-input"
          type="email"
          id="empresa-correo"
          name="company_email"
          placeholder="correo@empresa.com"
          autocomplete="email"
          maxlength="254"
        />
      {% endcall %}
    {% endcall %}

    {# Prefijo fijo España — no visible #}
    <input type="hidden" name="country_code" value="ES" />

    {# ── Teléfono ─────────────────────────────────────────────────────── #}
    {% call molecules.formField('Teléfono de contacto', 'empresa-telefono') %}
      {% call molecules.formInputIcon() %}
        <span class="form-input-wrapper__icon" aria-hidden="true">
          <svg class="svg svg--md" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 256 256" fill="currentColor">
            <path d="M222.37,158.46l-47.11-21.11-.13-.06a16,16,0,0,0-15.17,1.4,8.12,8.12,0,0,0-.75.56L134.87,160c-15.42-7.49-31.34-23.29-38.83-38.51l20.78-24.71c.2-.25.39-.5.57-.77a16,16,0,0,0,1.32-15.06l0-.12L97.54,33.64a16,16,0,0,0-16.62-9.52A56.26,56.26,0,0,0,32,80c0,79.4,64.6,144,144,144a56.26,56.26,0,0,0,55.88-48.92A16,16,0,0,0,222.37,158.46ZM176,208A128.14,128.14,0,0,1,48,80,40.2,40.2,0,0,1,82.87,40a.61.61,0,0,0,0,.12l21,47L83.2,111.86a6.13,6.13,0,0,0-.57.77,16,16,0,0,0-1,15.7c9.06,18.53,27.73,37.06,46.46,46.11a16,16,0,0,0,15.75-1.14,8.44,8.44,0,0,0,.74-.56L168.89,152l47,21.05h0s.08,0,.11,0A40.21,40.21,0,0,1,176,208Z"/>
          </svg>
        </span>
        <input
          class="form-input"
          type="tel"
          id="empresa-telefono"
          name="phone"
          placeholder="600 000 000"
          autocomplete="tel-national"
          maxlength="20"
        />
      {% endcall %}
    {% endcall %}

  </div>

  {# ── Tipo de solicitud — radio buttons ────────────────────────────── #}
  <div class="form-solicitud__section">
    <div class="form-group" role="radiogroup" aria-labelledby="tipo-solicitud-legend">
      <p id="tipo-solicitud-legend" class="form-label">Tipo de solicitud</p>

      <label class="form-choice">
        <input
          class="form-choice__input"
          type="radio"
          name="is_member"
          value="true"
          id="tipo-beneficiario"
        />
        <span class="form-choice__label">Ya soy beneficiario</span>
      </label>

      <label class="form-choice">
        <input
          class="form-choice__input"
          type="radio"
          name="is_member"
          value="false"
          id="tipo-empresa"
        />
        <span class="form-choice__label">Empresa interesada</span>
      </label>

    </div>
  </div>

  {# ── Mensaje libre (siempre requerido — campo "message" del backend) ── #}
  <div
    class="form-solicitud__conditional"
    id="solicitud-mensaje"
    aria-hidden="true"
  >
    {% call molecules.formField('Cuéntanos tu situación', 'solicitud-detalle') %}
      <p class="form-solicitud__helper">
        Incluye todos los detalles que normalmente enviarías por correo o Discord.
      </p>
      <div class="form-editor">
        <div class="form-editor__header">
          <div class="form-editor__tabs">
            <button type="button" class="form-editor__tab form-editor__tab--active" aria-selected="true">
              Escribir
            </button>
          </div>
        </div>
        <div class="form-editor__body">
          <textarea
            class="form-textarea"
            id="solicitud-detalle"
            name="message"
            rows="8"
            maxlength="2000"
            placeholder="Escribe aquí con todos los detalles..."
          ></textarea>
        </div>
      </div>
    {% endcall %}
  </div>

  {# ── Condiciones ───────────────────────────────────────────────────── #}
  <div class="form-solicitud__section">
    <div class="form-group">

      <label class="form-choice">
        <input
          class="form-choice__input"
          type="checkbox"
          id="acepta-terminos"
          name="privacy_accepted"
          required
        />
        <span class="form-choice__label">
          He leído y acepto los
          <a href="/legal/terminos">Términos y condiciones</a>
          y la
          <a href="/legal/privacidad">Política de privacidad</a>
        </span>
      </label>

    </div>
  </div>

  {# ── Turnstile ─────────────────────────────────────────────────────── #}
  <div class="form-solicitud__section">
    <div
      class="cf-turnstile"
      data-sitekey="{{ config.turnstileSiteKey }}"
      data-theme="light"
      data-language="es"
    ></div>
  </div>

  {# ── Feedback al usuario ───────────────────────────────────────────── #}
  <div
    class="form-solicitud__feedback"
    id="form-feedback"
    role="status"
    aria-live="polite"
    aria-atomic="true"
    hidden
  ></div>

  {# ── Enviar ────────────────────────────────────────────────────────── #}
  <div class="form-solicitud__actions">
    {{ atoms.button('Enviar formulario', '', 'primary', 'md', false, 'submit', 'form-submit-btn') }}
  </div>

</form>

<div id="form-solicitud-exito" class="form-solicitud__exito" hidden>
  <h2 class="form-solicitud__exito-titulo">¡Solicitud enviada!</h2>
  <p class="form-solicitud__exito-texto">
    Gracias, nos pondremos en contacto contigo cuando podamos.
    Recibirás un mensaje en tu correo electrónico confirmando que hemos recibido tu solicitud.
  </p>
</div>
