{#
  PARTIAL: FORM-SOLICITUD
  Formulario de presentar solicitud / nueva herramienta
  BEM: .form-solicitud (organismo)
  Wireframe: estilos blocky, escala de grises
#}

<form
  class="form-solicitud"
  id="form-solicitud"
  method="post"
  action="/api/contact"
  novalidate
>

  {# ── Honeypot — oculto para usuarios, atrae bots ──────────────────── #}
  <div class="form-solicitud__honeypot" aria-hidden="true">
    <label for="website">No rellenes este campo</label>
    <input
      type="text"
      id="website"
      name="website"
      tabindex="-1"
      autocomplete="off"
    />
  </div>

  {# ── Datos de la empresa ───────────────────────────────────────────── #}
  <div class="form-solicitud__section">

    <div class="form-field">
      <label class="form-label" for="empresa-nombre">Nombre de la empresa</label>
      <div class="form-input-wrapper">
        <span class="form-input-wrapper__icon" aria-hidden="true">
          <svg class="svg svg--md" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none">
            <rect x="3" y="3" width="18" height="18" stroke="currentColor" stroke-width="1.5"/>
            <line x1="7" y1="9" x2="17" y2="9" stroke="currentColor" stroke-width="1.5"/>
            <line x1="7" y1="13" x2="17" y2="13" stroke="currentColor" stroke-width="1.5"/>
            <line x1="7" y1="17" x2="12" y2="17" stroke="currentColor" stroke-width="1.5"/>
          </svg>
        </span>
        <input
          class="form-input"
          type="text"
          id="empresa-nombre"
          name="company_name"
          placeholder="Nombre de la empresa..."
          autocomplete="organization"
          maxlength="150"
        />
      </div>
    </div>

    <div class="form-field">
      <label class="form-label" for="empresa-correo">Correo de contacto</label>
      <div class="form-input-wrapper">
        <span class="form-input-wrapper__icon" aria-hidden="true">
          <svg class="svg svg--md" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none">
            <rect x="3" y="5" width="18" height="14" stroke="currentColor" stroke-width="1.5"/>
            <polyline points="3,5 12,13 21,5" stroke="currentColor" stroke-width="1.5" fill="none"/>
          </svg>
        </span>
        <input
          class="form-input"
          type="email"
          id="empresa-correo"
          name="company_email"
          placeholder="correo@empresa.com"
          autocomplete="email"
          maxlength="254"
        />
      </div>
    </div>

    {# Prefijo fijo España — no visible #}
    <input type="hidden" name="country_code" value="ES" />

    {# ── Teléfono ─────────────────────────────────────────────────────── #}
    <div class="form-field">
      <label class="form-label" for="empresa-telefono">Teléfono de contacto</label>
      <div class="form-input-wrapper">
        <span class="form-input-wrapper__icon" aria-hidden="true">
          <svg class="svg svg--md" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none">
            <rect x="5" y="2" width="14" height="20" stroke="currentColor" stroke-width="1.5"/>
            <line x1="5" y1="17" x2="19" y2="17" stroke="currentColor" stroke-width="1.5"/>
            <circle cx="12" cy="19.5" r="0.75" fill="currentColor"/>
          </svg>
        </span>
        <input
          class="form-input"
          type="tel"
          id="empresa-telefono"
          name="phone"
          placeholder="600 000 000"
          autocomplete="tel-national"
          maxlength="20"
        />
      </div>
    </div>

  </div>

  {# ── Tipo de solicitud — radio buttons ────────────────────────────── #}
  <div class="form-solicitud__section">
    <div class="form-group" role="radiogroup" aria-labelledby="tipo-solicitud-legend">
      <p id="tipo-solicitud-legend" class="form-label">Tipo de solicitud</p>

      <label class="form-choice">
        <input
          class="form-choice__input"
          type="radio"
          name="is_member"
          value="true"
          id="tipo-beneficiario"
        />
        <span class="form-choice__label">Ya soy beneficiario</span>
      </label>

      <label class="form-choice">
        <input
          class="form-choice__input"
          type="radio"
          name="is_member"
          value="false"
          id="tipo-empresa"
        />
        <span class="form-choice__label">Empresa interesada</span>
      </label>

    </div>
  </div>

  {# ── Mensaje libre (siempre requerido — campo "message" del backend) ── #}
  <div
    class="form-solicitud__conditional"
    id="solicitud-mensaje"
    aria-live="polite"
    aria-hidden="true"
  >
    <div class="form-field">
      <label class="form-label" for="solicitud-detalle">Cuéntanos tu situación</label>
      <p class="form-solicitud__helper">
        Incluye todos los detalles que normalmente enviarías por correo o Discord.
      </p>
      <div class="form-editor">
        <div class="form-editor__header">
          <div class="form-editor__tabs">
            <button type="button" class="form-editor__tab form-editor__tab--active" aria-selected="true">
              Escribir
            </button>
          </div>
        </div>
        <div class="form-editor__body">
          <textarea
            class="form-textarea"
            id="solicitud-detalle"
            name="message"
            rows="8"
            maxlength="2000"
            placeholder="Escribe aquí con todos los detalles..."
          ></textarea>
        </div>
      </div>
    </div>
  </div>

  {# ── Condiciones ───────────────────────────────────────────────────── #}
  <div class="form-solicitud__section">
    <div class="form-group">

      <label class="form-choice">
        <input
          class="form-choice__input"
          type="checkbox"
          id="acepta-terminos"
          name="privacy_accepted"
          required
        />
        <span class="form-choice__label">
          He leído y acepto los
          <a href="/legal/terminos">Términos y condiciones</a>
          y la
          <a href="/legal/privacidad">Política de privacidad</a>
        </span>
      </label>

    </div>
  </div>

  {# ── Turnstile ─────────────────────────────────────────────────────── #}
  <div class="form-solicitud__section">
    <div
      class="cf-turnstile"
      data-sitekey="{{ config.turnstileSiteKey }}"
      data-theme="light"
      data-language="es"
    ></div>
  </div>

  {# ── Feedback al usuario ───────────────────────────────────────────── #}
  <div
    class="form-solicitud__feedback"
    id="form-feedback"
    role="status"
    aria-live="polite"
    aria-atomic="true"
    hidden
  ></div>

  {# ── Enviar ────────────────────────────────────────────────────────── #}
  <div class="form-solicitud__actions">
    <button type="submit" class="btn btn--primary btn--md" id="form-submit-btn">
      Enviar formulario
    </button>
  </div>

</form>
