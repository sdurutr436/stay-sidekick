<header class="header l-page__header">
  <div class="header__inner">

    {# Brand: favicon en mobile (<768px), logo horizontal en tablet/desktop (≥768px) #}
    <a href="/" class="header__brand" aria-label="{{ site.name }} — Inicio">
      <picture>
        <source
          media="(max-width: 767px)"
          srcset="/assets/img/favicon/stay-sidekick-fav-icon-512x512.png"
          type="image/png">
        <source
          srcset="/assets/img/header/stay-sidekick-512x256-light-mode.webp 512w,
                  /assets/img/header/stay-sidekick-1024x576-light-mode.webp 1024w"
          type="image/webp"
          sizes="(max-width: 767px) 120px, 160px">
        <source
          srcset="/assets/img/header/stay-sidekick-512x256-light-mode.png 512w,
                  /assets/img/header/stay-sidekick-1024x576-light-mode.png 1024w"
          type="image/png"
          sizes="(max-width: 767px) 120px, 160px">
        <img
          class="logo__img"
          src="/assets/img/header/stay-sidekick-512x256-light-mode.png"
          alt="{{ site.name }}"
          width="512"
          height="256"
          loading="eager"
          decoding="async"
          fetchpriority="high"
        >
      </picture>
    </a>

    {# Acciones: sesión + CTA — icono + texto en desktop; solo icono en mobile #}
    <nav class="header__actions" aria-label="Acciones de usuario">
      {{ atoms.button('Iniciar sesión', '/login', 'secondary', 'md', false, 'button', '', icon_signin) }}
      {{ atoms.button('Presentar solicitud', '/solicitud', 'primary', 'md', false, 'button', '', icon_solicitud) }}

      {# Toggle de tema (icono Sun/Moon). El JS de theme-toggle.js controla aria-label e icono visible #}
      <button
        type="button"
        class="btn btn--ghost btn--md btn--icon-only"
        data-theme-toggle
        aria-label="Activar modo oscuro"
      >
        <span class="theme-toggle__icon" data-theme-icon="moon" aria-hidden="true">{{ icon_moon | safe }}</span>
        <span class="theme-toggle__icon" data-theme-icon="sun" aria-hidden="true" style="display:none">{{ icon_sun | safe }}</span>
      </button>
    </nav>

  </div>
</header>
