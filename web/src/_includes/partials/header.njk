{#
  PARTIAL: HEADER
  Estructura BEM idéntica al componente Angular (header.html)
  Los estilos provienen de styles/components/_header.scss (compartido)
#}
<header class="header l-page__header">
  <div class="header__inner">

    {# Brand: ícono + nombre app #}
    <a href="/" class="header__brand logo" aria-label="{{ site.name }} — Inicio">
      <picture>
        <source srcset="/assets/img/stay-sidekick-big-logo.webp" type="image/webp">
        <img
          class="logo__img"
          src="/assets/img/stay-sidekick-big-logo.png"
          alt="{{ site.name }}"
          width="1536"
          height="1024"
          loading="eager"
          decoding="async"
          fetchpriority="high"
        >
      </picture>
    </a>

    {# Acciones: sesión + CTA #}
    <nav class="header__actions" aria-label="Acciones de usuario">
      {{ atoms.button('Iniciar sesión', '/login', 'secondary', 'md') }}
      {{ atoms.button('Presentar solicitud', '/solicitud', 'primary', 'md') }}
    </nav>

  </div>
</header>
