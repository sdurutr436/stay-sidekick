{#
  PARTIAL: HEADER
  Estructura BEM idéntica al componente Angular (header.html)
  Los estilos provienen de styles/components/_header.scss (compartido)
#}

{# Iconos para los botones (solo visibles en mobile via CSS) #}
{% set icon_signin %}<svg viewBox="0 0 256 256" fill="currentColor" width="20" height="20" xmlns="http://www.w3.org/2000/svg"><path d="M141.66,133.66l-40,40a8,8,0,0,1-11.32-11.32L116.69,136H24a8,8,0,0,1,0-16h92.69L90.34,93.66A8,8,0,0,1,101.66,82.34l40,40A8,8,0,0,1,141.66,133.66ZM200,32H160a8,8,0,0,0,0,16h32V208H160a8,8,0,0,0,0,16h40a8,8,0,0,0,8-8V40A8,8,0,0,0,200,32Z"/></svg>{% endset %}
{% set icon_solicitud %}<svg viewBox="0 0 256 256" fill="currentColor" width="20" height="20" xmlns="http://www.w3.org/2000/svg"><path d="M213.66,82.34l-56-56A8,8,0,0,0,152,24H56A16,16,0,0,0,40,40V216a16,16,0,0,0,16,16H200a16,16,0,0,0,16-16V88A8,8,0,0,0,213.66,82.34ZM160,51.31,188.69,80H160ZM200,216H56V40h88V88a8,8,0,0,0,8,8h48V216Zm-32-80a8,8,0,0,1-8,8H96a8,8,0,0,1,0-16h64A8,8,0,0,1,168,136Zm0,32a8,8,0,0,1-8,8H96a8,8,0,0,1,0-16h64A8,8,0,0,1,168,168Z"/></svg>{% endset %}

<header class="header l-page__header">
  <div class="header__inner">

    {# Brand: favicon en mobile, logo horizontal en tablet/desktop #}
    <a href="/" class="header__brand" aria-label="{{ site.name }} — Inicio">
      <picture>
        <source
          media="(max-width: 575px)"
          srcset="/assets/img/favicon/stay-sidekick-fav-icon-512x512.png"
          type="image/png">
        <source
          srcset="/assets/img/header/stay-sidekick-512x256-light-mode.webp 512w,
                  /assets/img/header/stay-sidekick-1024x576-light-mode.webp 1024w"
          type="image/webp"
          sizes="(max-width: 767px) 120px, 160px">
        <source
          srcset="/assets/img/header/stay-sidekick-512x256-light-mode.png 512w,
                  /assets/img/header/stay-sidekick-1024x576-light-mode.png 1024w"
          type="image/png"
          sizes="(max-width: 767px) 120px, 160px">
        <img
          class="logo__img"
          src="/assets/img/header/stay-sidekick-512x256-light-mode.png"
          alt="{{ site.name }}"
          width="512"
          height="256"
          loading="eager"
          decoding="async"
          fetchpriority="high"
        >
      </picture>
    </a>

    {# Acciones: sesión + CTA — en mobile solo iconos, en desktop solo texto #}
    <nav class="header__actions" aria-label="Acciones de usuario">
      {{ atoms.button('Iniciar sesión', '/login', 'secondary', 'md', false, 'button', '', icon_signin) }}
      {{ atoms.button('Presentar solicitud', '/solicitud', 'primary', 'md', false, 'button', '', icon_solicitud) }}
    </nav>

  </div>
</header>
