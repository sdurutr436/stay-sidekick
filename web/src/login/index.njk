---
layout: base.njk
title: Iniciar sesión
description: Accede a tu panel de Stay Sidekick.
section: login
---
{% import "macros/atoms.njk" as atoms %}

<section class="l-container">
  <div class="form-hero-layout">

    <section class="login-page">

      <header class="login-page__intro">
      <h1>Iniciar sesión</h1>
      <p class="u-text-secondary u-mt-4">
        Accede a tu panel de herramientas.
      </p>
    </header>

    <div class="alert alert--warning" id="acceso-alert" role="alert" aria-live="polite" hidden>
      <div class="alert__content">Para acceder a esta sección debes iniciar sesión.</div>
      <button class="alert__close" type="button" id="acceso-alert-close" aria-label="Cerrar aviso">
        <svg class="svg svg--xs" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 16 16" fill="none" aria-hidden="true">
          <line x1="4" y1="4" x2="12" y2="12" stroke="currentColor" stroke-width="1.5" stroke-linecap="square"/>
          <line x1="12" y1="4" x2="4" y2="12" stroke="currentColor" stroke-width="1.5" stroke-linecap="square"/>
        </svg>
      </button>
    </div>

    <form class="form-login" id="form-login" novalidate>

      {# ── Correo electrónico ──────────────────────────────────────────── #}
      <div class="form-field">
        <label class="form-label" for="login-email">Correo electrónico</label>
        <div class="form-input-wrapper">
          <span class="form-input-wrapper__icon" aria-hidden="true">
            <svg class="svg svg--md" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 256 256" fill="currentColor">
              <path d="M224,48H32a8,8,0,0,0-8,8V192a16,16,0,0,0,16,16H216a16,16,0,0,0,16-16V56A8,8,0,0,0,224,48Zm-96,85.15L52.57,64H203.43ZM98.71,128,40,181.81V74.19Zm11.84,10.85,12,11.05a8,8,0,0,0,10.82,0l12-11.05,58,53.15H52.57ZM157.29,128,216,74.18V181.82Z"/>
            </svg>
          </span>
          <input
            class="form-input"
            type="email"
            id="login-email"
            name="email"
            placeholder="correo@empresa.com"
            autocomplete="email"
          />
        </div>
      </div>

      {# ── Contraseña ──────────────────────────────────────────────────── #}
      <div class="form-field">
        <label class="form-label" for="login-password">Contraseña</label>
        <div class="form-input-wrapper">
          <span class="form-input-wrapper__icon" aria-hidden="true">
            <svg class="svg svg--md" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 256 256" fill="currentColor">
              <path d="M208,80H176V56a48,48,0,0,0-96,0V80H48A16,16,0,0,0,32,96V208a16,16,0,0,0,16,16H208a16,16,0,0,0,16-16V96A16,16,0,0,0,208,80ZM96,56a32,32,0,0,1,64,0V80H96ZM208,208H48V96H208V208Zm-68-56a12,12,0,1,1-12-12A12,12,0,0,1,140,152Z"/>
            </svg>
          </span>
          <input
            class="form-input"
            type="password"
            id="login-password"
            name="password"
            placeholder="••••••••"
            autocomplete="current-password"
          />
        </div>
      </div>

      {# ── Enviar ──────────────────────────────────────────────────────── #}
      <div class="form-login__actions">
        {{ atoms.button('Iniciar sesión', '', 'primary', 'md', false, 'submit') }}
      </div>

      {# ── Pie — enlace a solicitud ─────────────────────────────────────── #}
      <p class="form-login__footer">
        ¿Sin acceso todavía?
        <a href="/solicitud">Presentar solicitud</a>
      </p>

    </form>

    </section>

    <div class="form-hero-layout__img" aria-hidden="true">
      <picture>
        <source
          srcset="/assets/img/heroes/female-staff-giving-boarding-pass-businessman-1024x683.webp"
          type="image/webp">
        <img
          src="/assets/img/heroes/female-staff-giving-boarding-pass-businessman-1024x683.jpg"
          alt=""
          width="1024"
          height="683"
          loading="lazy"
          decoding="async"
        >
      </picture>
    </div>

  </div>
</section>

{% block scripts %}
<script src="/assets/js/form-login.js" defer></script>
{% endblock %}
