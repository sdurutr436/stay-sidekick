---
layout: base.njk
title: Contacto
description: Ponte en contacto con Stay Sidekick.
section: empresa
---

{% import "macros/atoms.njk" as atoms %}
{% import "macros/molecules.njk" as molecules %}
{% import "macros/organisms.njk" as organisms %}

<div class="web-page">

  {{ organisms.pageHeader('Contacto', '¿Tienes alguna pregunta, propuesta o quieres colaborar? Escríbenos.') }}

  <div class="web-page__two-col web-page__section web-page__section--last">

    {# Columna izquierda: info de contacto #}
    <aside class="web-page__prose" aria-label="Información de contacto directo">
      <h2>Contacto directo</h2>
      <p class="u-text-secondary">
        Prefiero el correo electrónico para consultas detalladas. También puedes encontrarme
        en las redes profesionales.
      </p>

      <ul class="web-page__links">
        <li>
          <a href="mailto:duran.utrerasergio2612@gmail.com" aria-label="Enviar correo a duran.utrerasergio2612@gmail.com">
            duran.utrerasergio2612@gmail.com
          </a>
        </li>
        <li>
          <a href="https://www.linkedin.com/in/sergio-dur%C3%A1n-utrera/" target="_blank" rel="noopener noreferrer"
             aria-label="Perfil de LinkedIn de Sergio Durán Utrera">
            LinkedIn
          </a>
        </li>
        <li>
          <a href="https://github.com/sdurutr436" target="_blank" rel="noopener noreferrer"
             aria-label="Perfil de GitHub de Sergio Durán Utrera">
            GitHub
          </a>
        </li>
      </ul>
    </aside>

    {# Columna derecha: formulario #}
    <section class="web-page__prose" aria-labelledby="contacto-formulario-titulo">
      <h2 id="contacto-formulario-titulo">Enviar un mensaje</h2>

      {# TODO: Conectar al endpoint serverless cuando esté disponible #}
      <form
        class="form-solicitud"
        method="post"
        action=""
        novalidate
      >

        <div class="form-solicitud__section">
          {% call molecules.formField('Nombre', 'contacto-nombre') %}
            {% call molecules.formInputIcon() %}
              <span class="form-input-wrapper__icon" aria-hidden="true">
                <svg class="svg svg--md" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 256 256" fill="currentColor">
                  <path d="M230.92,212c-15.23-26.33-38.7-45.21-66.09-54.16a72,72,0,1,0-73.66,0C63.78,166.78,40.31,185.66,25.08,212a8,8,0,1,0,13.85,8c18.84-32.56,52.14-52,89.07-52s70.23,19.44,89.07,52a8,8,0,1,0,13.85-8ZM72,96a56,56,0,1,1,56,56A56.06,56.06,0,0,1,72,96Z"/>
                </svg>
              </span>
              <input
                class="form-input"
                type="text"
                id="contacto-nombre"
                name="nombre"
                placeholder="Tu nombre completo"
                autocomplete="name"
                maxlength="100"
                required
              >
            {% endcall %}
          {% endcall %}

          {% call molecules.formField('Correo electrónico', 'contacto-email') %}
            {% call molecules.formInputIcon() %}
              <span class="form-input-wrapper__icon" aria-hidden="true">
                <svg class="svg svg--md" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 256 256" fill="currentColor">
                  <path d="M224,48H32a8,8,0,0,0-8,8V192a16,16,0,0,0,16,16H216a16,16,0,0,0,16-16V56A8,8,0,0,0,224,48Zm-96,85.15L52.57,64H203.43ZM98.71,128,40,181.81V74.19Zm11.84,10.85,12,11.05a8,8,0,0,0,10.82,0l12-11.05,58,53.15H52.57ZM157.29,128,216,74.18V181.82Z"/>
                </svg>
              </span>
              <input
                class="form-input"
                type="email"
                id="contacto-email"
                name="email"
                placeholder="tu@correo.com"
                autocomplete="email"
                maxlength="254"
                required
              >
            {% endcall %}
          {% endcall %}

          {% call molecules.formField('Empresa (opcional)', 'contacto-empresa') %}
            {% call molecules.formInputIcon() %}
              <span class="form-input-wrapper__icon" aria-hidden="true">
                <svg class="svg svg--md" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 256 256" fill="currentColor">
                  <path d="M240,208H224V96a16,16,0,0,0-16-16H144V32a16,16,0,0,0-24.88-13.32L39.12,72A16,16,0,0,0,32,85.34V208H16a8,8,0,0,0,0,16H240a8,8,0,0,0,0-16ZM208,96V208H144V96ZM48,85.34,128,32V208H48ZM112,112v16a8,8,0,0,1-16,0V112a8,8,0,1,1,16,0Zm-32,0v16a8,8,0,0,1-16,0V112a8,8,0,1,1,16,0Zm0,56v16a8,8,0,0,1-16,0V168a8,8,0,0,1,16,0Zm32,0v16a8,8,0,0,1-16,0V168a8,8,0,0,1,16,0Z"/>
                </svg>
              </span>
              <input
                class="form-input"
                type="text"
                id="contacto-empresa"
                name="empresa"
                placeholder="Nombre de tu empresa"
                autocomplete="organization"
                maxlength="150"
              >
            {% endcall %}
          {% endcall %}

          {% call molecules.formField('Mensaje', 'contacto-mensaje') %}
            <textarea
              class="form-input"
              id="contacto-mensaje"
              name="mensaje"
              placeholder="Cuéntanos en qué podemos ayudarte..."
              rows="5"
              maxlength="2000"
              required
            ></textarea>
          {% endcall %}
        </div>

        {# TODO: Insertar widget Turnstile aquí — ver docs/todo/turnstile.md #}

        {{ atoms.button('Enviar mensaje', '', 'primary', 'md', false, 'submit') }}

      </form>
    </section>

  </div>

</div>
