---
layout: base.njk
title: Presentar solicitud
description: Presenta tu solicitud de estancia o de nueva herramienta en Stay Sidekick.
section: solicitud
---

<div class="l-container">
  <div class="solicitud-page">

    <div class="solicitud-page__intro">
      <h1>Presentar solicitud</h1>
      <p class="u-text-secondary u-mt-4">
        Rellena el formulario para ponerte en contacto con nosotros.
        Si ya eres beneficiario, selecciona la opción correspondiente
        para enviarnos un mensaje con todos los detalles.
      </p>
    </div>

    {% include "partials/form-solicitud.njk" %}

  </div>
</div>

<script>
  (function () {
    var radios     = document.querySelectorAll('input[name="tipo_solicitud"]');
    var conditional = document.getElementById('solicitud-mensaje');

    if (!conditional) return;

    radios.forEach(function (radio) {
      radio.addEventListener('change', function () {
        var isVisible = this.value === 'beneficiario';
        conditional.classList.toggle('form-solicitud__conditional--visible', isVisible);
        conditional.setAttribute('aria-hidden', String(!isVisible));
      });
    });
  }());
</script>
