# =============================================================================
# WEB — Variables de entorno del sitio estático (11ty)
# Copiar como .env y rellenar los valores reales antes de compilar
# =============================================================================

# ── Cloudflare Turnstile ──────────────────────────────────────────────────────
# Site key PÚBLICA — se incrusta en el HTML del formulario de contacto
# Obtener en: https://dash.cloudflare.com → Turnstile → Add site
# La secret key (privada) va en backend/.env como TURNSTILE_SECRET_KEY
TURNSTILE_SITE_KEY=tu-turnstile-site-key-publica
